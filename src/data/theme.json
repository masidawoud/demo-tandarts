{
  "preset": "warm-editorial",
  "fonts": {
    "display_family": "Cormorant Garamond",
    "display_url": "Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500",
    "body_family": "DM Sans",
    "body_url": "DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300",
    "display_fallback": "Georgia, serif",
    "body_fallback": "system-ui, -apple-system, sans-serif"
  },
  "colors": {
    "accent":       "#2D7A6C",
    "accent_hover": "#226359",
    "accent_light": "#EBF5F2",
    "bg":           "#FAF7F2",
    "bg_alt":       "#F0E9DE",
    "bg_dark":      "#1C1917",
    "text":         "#1C1917",
    "text_muted":   "#78716C",
    "text_light":   "#FAF7F2",
    "border":       "#E5DDD3",
    "star":         "#F5A623"
  },
  "radius": {
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2.5rem"
  }
}
